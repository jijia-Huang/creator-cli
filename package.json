{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "creator-cli",
    "version": "1.0.0",
    "author": "Jijia-Huang",
    "editor": ">=3.8.0",
    "bin": {
        "creator-cli": "./bin/creator-cli.js"
    },
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "npx --yes tsc",
        "cli": "node bin/creator-cli.js",
        "sync-cli-global": "node -e \"require('fs').copyFileSync('bin/creator-cli.js', 'creator-cli-global/bin/creator-cli.js')\""
    },
    "description": "i18n:creator-cli.description",
    "main": "./dist/main.js",
    "dependencies": {
        "vue": "^3.1.4",
        "fs-extra": "^10.0.0"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.0",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "creator-cli Default Panel",
            "type": "dockable",
            "main": "dist/panels/default",
            "size": {
                "min-width": 400,
                "min-height": 300,
                "width": 1024,
                "height": 600
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.panel/creator-cli",
                "label": "i18n:creator-cli.open_panel",
                "message": "open-panel"
            },
            {
                "path": "i18n:menu.develop/creator-cli",
                "label": "i18n:creator-cli.send_to_panel",
                "message": "send-to-panel"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": [
                    "openPanel"
                ]
            },
            "send-to-panel": {
                "methods": [
                    "default.hello"
                ]
            },
            "start-bridge": {
                "methods": [
                    "startBridge"
                ]
            },
            "stop-bridge": {
                "methods": [
                    "stopBridge"
                ]
            },
            "get-bridge-status": {
                "methods": [
                    "getBridgeStatus"
                ]
            }
        }
    }
}
